      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"username\": \"seller1\",\n  \"email\": \"seller@mail.com\",\n  \"passwordHash\": \"1234\",\n  \"firstName\": \"Juan\",\n  \"lastName\": \"Lopez\",\n  \"role\": \"seller\",\n  \"phone\": \"1155667788\"\n}"
      }
