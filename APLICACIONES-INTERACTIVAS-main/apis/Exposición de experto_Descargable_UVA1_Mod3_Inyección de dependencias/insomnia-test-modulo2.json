      "_id": "req_14_update_order_shipped",
      "_type": "request",
      "parentId": "fld_05_entrega",
      "name": "14. Actualizar estado de orden a enviada",
      "method": "PUT",
      "url": "http://localhost:8080/orders/1",
      "description": "Reemplazar 1 con el orderId",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": 1,\n  \"shippingAddressId\": 1,\n  \"status\": \"shipped\"\n}"
      }
    },
    {
      "_id": "req_15_update_delivery_delivered",
