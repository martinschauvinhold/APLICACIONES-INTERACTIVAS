      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"orderId\": 1,\n  \"shippingMethod\": \"correo_argentino\",\n  \"trackingNumber\": \"CA-20260412-001\",\n  \"deliveryStatus\": \"delivered\"\n}"
      }
    },
    {
      "_id": "req_16_update_order_delivered",
      "_type": "request",
      "parentId": "fld_05_entrega",
