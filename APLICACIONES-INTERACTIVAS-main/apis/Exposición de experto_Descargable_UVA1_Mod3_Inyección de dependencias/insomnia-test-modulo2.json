      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"orderId\": 1,\n  \"shippingMethod\": \"correo_argentino\",\n  \"trackingNumber\": \"CA-20260412-001\",\n  \"deliveryStatus\": \"dispatched\"\n}"
      }
    },
