        "text": "{\n  \"productId\": 1,\n  \"sku\": \"REM-NIKE-M-AZ\",\n  \"attributes\": \"{\\\"talle\\\": \\\"M\\\"}\",\n  \"basePrice\": 9500.00\n}"
