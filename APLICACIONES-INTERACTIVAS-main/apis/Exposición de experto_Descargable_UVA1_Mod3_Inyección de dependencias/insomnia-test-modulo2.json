      "parentId": "fld_03_orden",
      "name": "9b. Agregar item a la orden (reemplazar orderId y variantId)",
      "method": "POST",
      "url": "http://localhost:8080/order-items",
      "description": "El precio se toma automaticamente del basePrice de la variante. Se puede llamar varias veces para agregar mas items.",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"orderId\": 1,\n  \"variantId\": 1,\n  \"quantity\": 2\n}"
      }
    },
    {
      "_id": "req_09c_get_items",
      "_type": "request",
      "parentId": "fld_03_orden",
      "name": "9c. Ver items de la orden",
      "method": "GET",
      "url": "http://localhost:8080/order-items/order/1",
      "description": "Reemplazar 1 con el orderId. Verifica que totalAmount se haya calculado en la orden."
    },

    {
      "_id": "req_10_create_payment",
      "_type": "request",
      "parentId": "fld_04_pago",
      "name": "10. Registrar pago (reemplazar orderId)",
      "method": "POST",
      "url": "http://localhost:8080/payments",
      "description": "Reemplazar orderId con el id de la orden creada",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"orderId\": 1,\n  \"paymentMethod\": \"credit_card\",\n  \"transactionId\": \"TXN-20260412-001\",\n  \"paymentStatus\": \"approved\"\n}"
      }
    },
    {
      "_id": "req_11_update_order_paid",
      "_type": "request",
      "parentId": "fld_04_pago",
      "name": "11. Actualizar estado de orden a pagada",
      "method": "PUT",
      "url": "http://localhost:8080/orders/1",
      "description": "Reemplazar 1 con el orderId. Actualizar el status una vez confirmado el pago",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": 1,\n  \"shippingAddressId\": 1,\n  \"status\": \"paid\"\n}"
      }
    },
    {
      "_id": "req_12_get_payments_order",
      "_type": "request",
      "parentId": "fld_04_pago",
      "name": "12. Ver pagos de la orden",
