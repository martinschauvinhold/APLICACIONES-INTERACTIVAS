# Copiá este archivo como .env y ajustá los valores según tu entorno.
# El .env real está en .gitignore y nunca se sube al repo.

# ─── SQL Server ─────────────────────────────────────────────────────────
# Para Docker (perfil docker):
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=E-commerce;encrypt=true;trustServerCertificate=true
DB_USER=sa
DB_PASS=YourStrong@Passw0rd

# Para SQLEXPRESS local (perfil por defecto):
# DB_URL=jdbc:sqlserver://localhost\\SQLEXPRESS;databaseName=E-commerce;encrypt=true;trustServerCertificate=true
# DB_USER=appuser
# DB_PASS=App12345!

# ─── MySQL ──────────────────────────────────────────────────────────────
# Descomentá estas líneas (y comentá las de SQL Server) si usás MySQL.
# Sirven tanto para el perfil 'mysql' (local) como 'docker-mysql' (contenedor).
# DB_URL=jdbc:mysql://localhost:3306/ecommerce?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# DB_USER=appuser
# DB_PASS=App12345!

# ─── JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=reemplaza-con-una-clave-hex-de-64-chars-minimo
